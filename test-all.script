#!/bin/bash

# ============================================================
#  Integration Test Script
#  Tests: Course Aggregate API
# ============================================================

HOST=${HOST:-localhost}
PORT=${PORT:-8443}
HEALTH_URL="https://${HOST}:${PORT}/actuator/health"
BASE_URL="https://${HOST}:${PORT}/api/v1/aggregate"
CERT_FILE="${CERT_FILE:-microservices/gateway-service/src/main/resources/certificates/cert.pem}"
TLS_ARGS=(--cacert "$CERT_FILE")

# --- Colours ---
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Colour

PASS=0
FAIL=0

# ============================================================
# Helpers
# ============================================================

log()     { echo -e "${CYAN}[INFO]${NC}  $*"; }
success() { echo -e "${GREEN}[PASS]${NC}  $*"; }
error()   { echo -e "${RED}[FAIL]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }

# Assert two values are equal
assertEqual() {
  local expected="$1"
  local actual="$2"
  local label="${3:-assertEqual}"

  if [ "$expected" == "$actual" ]; then
    success "$label → expected='$expected' actual='$actual'"
    ((PASS++))
  else
    error  "$label → expected='$expected' actual='$actual'"
    ((FAIL++))
  fi
}

# Call endpoint, assert HTTP status code, return body
assertHttpCode() {
  local expected_code="$1"
  local url="$2"
  local method="${3:-GET}"
  local body="${4:-}"

  local response
  local http_code

  if [ "$method" == "POST" ] && [ -n "$body" ]; then
    response=$(curl "${TLS_ARGS[@]}" -s -w "\n%{http_code}" \
      -X POST "$url" \
      -H "Content-Type: application/json" \
      -d "$body")
  else
    response=$(curl "${TLS_ARGS[@]}" -s -w "\n%{http_code}" "$url")
  fi

  http_code=$(echo "$response" | tail -n1)
  body_only=$(echo "$response" | sed '$d')

  if [ "$http_code" == "$expected_code" ]; then
    success "HTTP $expected_code ← $method $url" >&2
    ((PASS++))
  else
    error  "HTTP $expected_code expected but got $http_code ← $method $url" >&2
    ((FAIL++))
  fi

  echo "$body_only"
}

# ============================================================
# Step 1: Wait for Health Actuator
# ============================================================

waitForHealth() {
  local url="$HEALTH_URL"
  local max_retries=${MAX_RETRIES:-20}
  local wait_seconds=${RETRY_INTERVAL:-5}
  local attempt=1

  log "Waiting for service health at: $url"
  log "Max retries: $max_retries | Interval: ${wait_seconds}s"

  while [ $attempt -le $max_retries ]; do
    log "Attempt $attempt/$max_retries..."

    http_code=$(curl "${TLS_ARGS[@]}" -s -o /dev/null -w "%{http_code}" "$url")

    if [ "$http_code" == "200" ]; then
      success "Service is UP (HTTP 200) after $attempt attempt(s)"
      return 0
    fi

    warn "Service not ready yet (HTTP $http_code). Retrying in ${wait_seconds}s..."
    sleep "$wait_seconds"
    ((attempt++))
  done

  error "Service did not become healthy after $((max_retries * wait_seconds))s. Giving up."
  exit 1
}

# ============================================================
# Step 2: POST — Create Course Aggregate
# ============================================================

createCourseAggregate() {
  log "Creating course aggregate..."

  local body='{
    "course": {
      "name": "course-bash-script"
    },
    "recommendations": [
      { "author": "author 1", "rate": 1, "content": "content 1" }
    ],
    "reviews": [
      { "author": "author 1", "subject": "subject 1", "content": "content 1" }
    ]
  }'

  local response
  response=$(curl "${TLS_ARGS[@]}" -s -D - -X POST "${BASE_URL}/course" \
    -H "Content-Type: application/json" \
    -d "$body")

  # Extract Location header value e.g. http://localhost:8080/course-composite/abc-123
  local location
  location=$(echo "$response" | grep -i "^location:" | tr -d '\r' | awk '{print $2}')

  # Extract the aggregate/course ID from response
  aggregateId=$(echo "$location" | awk -F'/' '{print $NF}')
  if [ -z "$aggregateId" ] || [ "$aggregateId" == "null" ]; then
    error "Could not extract aggregateId from POST response"
    echo "Response body: $response"
    ((FAIL++))
    exit 1
  fi

  success "Course created with id = $aggregateId"
}

# ============================================================
# Step 3: GET — Verify Course Aggregate
# ============================================================

verifyCourseAggregate() {
 log "Fetching and verifying course aggregate (id=$aggregateId)..."
   local response
   local attempts=5
   local delay=5

   for i in $(seq 1 $attempts); do
     response=$(assertHttpCode 200 "${BASE_URL}/course/${aggregateId}")
     if [ $? -eq 0 ]; then
       echo "$response"
       # Assert course ID matches
       assertEqual "$aggregateId" "$(echo "$response" | jq -r '.course.courseId')" \
         "course.courseId matches"

       # Assert exactly 1 recommendation
       assertEqual 1 "$(echo "$response" | jq '.recommendations | length')" \
         "recommendations count = 1"

       # Assert exactly 1 review
       assertEqual 1 "$(echo "$response" | jq '.reviews | length')" \
         "reviews count = 1"
       return 0
     fi
     log "Attempt $i/$attempts failed. Retrying in ${delay}s..."
     sleep $delay
   done
}

# ============================================================
# Results Summary
# ============================================================

printSummary() {
  echo ""
  echo "============================================"
  echo -e "  Results: ${GREEN}$PASS passed${NC} | ${RED}$FAIL failed${NC}"
  echo "============================================"

  if [ $FAIL -eq 0 ]; then
    success "All tests passed! ✅"
    exit 0
  else
    error "$FAIL test(s) failed ❌"
    exit 1
  fi
}
die() {
  echo -e "\n❌ ERROR: $1"
  echo "   Command failed at line ${BASH_LINENO[0]}"
  exit 1
}
# ============================================================
# Run
# ============================================================

echo ""
echo "============================================"
echo "   Course Aggregate Integration Tests"
echo "============================================"
echo ""

if [[ $@ == "start" ]]
then
  echo "Building jar files..."
  ./mvnw clean install -q 2>&1 | grep -E "ERROR|FAIL|BUILD" || die "Maven build failed"

  echo "Tearing down docker environment..."
  docker compose down --remove-orphans --volumes || die "docker compose down failed"

  echo "Building and starting containers..."
  docker compose up -d --build || die "docker compose up failed"

  echo "✅ Environment started successfully"
fi


waitForHealth
echo ""
createCourseAggregate
echo ""
verifyCourseAggregate
echo ""
printSummary
